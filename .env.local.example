# =================================================================
# CONECTAR HR - VARIABLES DE ENTORNO
# Copia este archivo a .env.local y configura tus valores
# =================================================================

# -----------------------------------------------------------------
# SESIÓN Y SEGURIDAD
# -----------------------------------------------------------------

# Duración de la sesión en horas (máximo 8)
NEXT_PUBLIC_SESSION_TTL_HOURS=4

# -----------------------------------------------------------------
# SUPABASE (Base de datos y Autenticación)
# -----------------------------------------------------------------

# URL de tu proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anónima pública de Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------
# ASISTENTE IA (Anthropic API)
# -----------------------------------------------------------------

# API Key de Anthropic para el Asistente IA
# NOTA: En producción, usar Route Handler para proteger esta key
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------
# AWS S3 (Backups y Archivos)
# -----------------------------------------------------------------

# Bucket de S3 para backups
AWS_S3_BUCKET=conectar-hr-backups

# Región de AWS
AWS_REGION=us-east-1

# Credenciales de AWS (usar en producción, no en desarrollo)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------
# VARIABLES DE PRODUCCIÓN
# -----------------------------------------------------------------

# URL base de la aplicación en producción
NEXT_PUBLIC_APP_URL=https://tu-dominio.com

# Cookie segura solo en HTTPS (activar en producción)
# COOKIE_SECURE=true
